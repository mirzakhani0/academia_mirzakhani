rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Función auxiliar para verificar si el usuario está autenticado
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Función para verificar si el usuario es admin
    function isAdmin() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol == 'admin';
    }
    
    // Función para verificar si el usuario es dueño del documento
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // ===== USUARIOS =====
    match /usuarios/{userId} {
      // Los usuarios autenticados pueden leer su propio perfil
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      
      // Los usuarios pueden crear su propio perfil al registrarse
      allow create: if isAuthenticated() && isOwner(userId);
      
      // Solo el usuario puede actualizar su propio perfil, o un admin
      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin());
      
      // Solo un admin puede eliminar usuarios
      allow delete: if isAdmin();
    }
    
    // ===== CURSOS =====
    match /cursos/{cursoId} {
      // Cualquiera autenticado puede leer cursos activos
      allow read: if isAuthenticated();
      
      // Solo admins pueden crear, actualizar o eliminar cursos
      allow create, update, delete: if isAdmin();
    }
    
    // ===== SOLICITUDES =====
    match /solicitudes/{solicitudId} {
      // Cualquiera autenticado puede leer solicitudes
      allow read: if isAuthenticated();
      
      // Los usuarios pueden crear sus propias solicitudes
      allow create: if isAuthenticated() && 
                       request.resource.data.email == request.auth.token.email;
      
      // Solo admins pueden actualizar o eliminar solicitudes
      allow update, delete: if isAdmin();
    }
    
    // ===== CONTENIDOS =====
    match /contenidos/{contenidoId} {
      // Solo admins pueden leer, crear, actualizar o eliminar contenidos
      allow read, create, update, delete: if isAdmin();
    }
    
    // ===== MATRÍCULAS =====
    match /matriculas/{matriculaId} {
      // Los usuarios pueden leer sus propias matrículas
      allow read: if isAuthenticated() && 
                     (isOwner(matriculaId) || isAdmin());
      
      // Los usuarios pueden crear sus propias matrículas
      allow create: if isAuthenticated() && isOwner(matriculaId);
      
      // Solo admins pueden actualizar o eliminar matrículas
      allow update, delete: if isAdmin();
    }
  }
}
