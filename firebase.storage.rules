rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Función para verificar si el usuario está autenticado
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Función para verificar si el usuario es admin
    function isAdmin() {
      return request.auth != null && 
             request.auth.token.admin == true;
    }
    
    // Carpeta pública - cualquiera puede leer
    match /public/{allPaths=**} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    
    // Carpeta de usuarios - solo el dueño puede escribir
    match /usuarios/{userId}/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }
    
    // Carpeta de cursos - solo admins pueden escribir
    match /cursos/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Carpeta de contenidos - solo admins pueden escribir
    match /contenidos/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
